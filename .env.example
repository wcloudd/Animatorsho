APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FORCE_HTTPS=false

# Production core settings (uncomment and set on production server):
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://animatorsho.ir
# FORCE_HTTPS=true

# Trust reverse-proxy headers (X-Forwarded-Proto, Host, Port, For).
# Defaults to "*" in local/testing. Set to load-balancer IP(s) in production,
# or leave unset on Laravel Forge / Vapor.
# TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local development uses SQLite. The file lives at database/database.sqlite.
# Changing DB_CONNECTION does not delete or modify that file.
DB_CONNECTION=sqlite

# --- Production PostgreSQL (do not use sqlite in production) ---
# DB_CONNECTION=pgsql
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Zarinpal (production: set merchant ID and ZARINPAL_SANDBOX=false)
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true

# Card-to-card manual payment (shown to users at checkout)
CARD_TO_CARD_NUMBER=
CARD_TO_CARD_OWNER_NAME=
CARD_TO_CARD_RECEIPT_MAX_KB=5120

# SMS / FarazSMS (production: SMS_DRIVER=farazsms, SMS_ENABLED=true)
# Automated tests force SMS_DRIVER=fake via phpunit.xml — see docs/postgresql-deploy.md
# OTP login uses the otp_login template — register its pattern with FarazSMS before launch.
SMS_DRIVER=log
SMS_ENABLED=false
SMS_ADMIN_MOBILE=

FARAZSMS_API_KEY=
FARAZSMS_SENDER=
FARAZSMS_BASE_URL=https://api.iranpayamak.com/ws/v1

# SpotPlayer license API (production: SPOTPLAYER_ENABLED=true)
SPOTPLAYER_ENABLED=false
SPOTPLAYER_API_BASE_URL=https://panel.spotplayer.ir
SPOTPLAYER_API_KEY=
SPOTPLAYER_TIMEOUT=15
SPOTPLAYER_TEST_MODE=false
